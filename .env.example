# Token del bot (Obtenido en Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=tu_token_aqui

# ID de la aplicación / Client ID (Obtenido en Discord Developer Portal -> General Information -> Application ID)
CLIENT_ID=tu_client_id_aqui

# Opcional: ID de tu servidor de pruebas (Guild ID) para registro rápido de comandos instantáneos
GUILD_ID=tu_guild_id_aqui

# Puerto para el servidor Express del Dashboard
PORT=3000

# Cadena de conexión para la base de datos PostgreSQL
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db?sslmode=disable

# --- Voces de IA (Fish Audio) para /decir ---
# API Key de Fish Audio (créala gratis en https://fish.audio -> Account -> API Keys)
# Si se deja vacía, /decir usará solo la voz clásica de Google
FISH_AUDIO_API_KEY=

# Opcional: ID del modelo de la voz de El Xokas (por defecto usa el modelo comunitario "xokas")
FISH_AUDIO_XOKAS_MODEL_ID=8f23453397d14e4d9a579bad5aab41a8

# Opcional: ID del modelo de la voz E-girl (por defecto usa el modelo comunitario "Chica Sexy LMO")
FISH_AUDIO_EGIRL_MODEL_ID=03cfefd0ad67452c8d291d0ae4605273

# Opcional: modelo TTS de Fish Audio (s2.1-pro recomendado; s2.1-pro-free es gratuito para desarrollo)
FISH_AUDIO_MODEL=s2.1-pro
