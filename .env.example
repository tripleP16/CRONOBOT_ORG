# Token del bot (Obtenido en Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=tu_token_aqui

# ID de la aplicación / Client ID (Obtenido en Discord Developer Portal -> General Information -> Application ID)
CLIENT_ID=tu_client_id_aqui

# Opcional: ID de tu servidor de pruebas (Guild ID) para registro rápido de comandos instantáneos
GUILD_ID=tu_guild_id_aqui

# Puerto para el servidor Express del Dashboard
PORT=3000

# Cadena de conexión para la base de datos PostgreSQL
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db?sslmode=disable
